# Copy this file to the repo ROOT as `.env` (next to README.md).
# Never commit `.env` — it is gitignored.

# Option A — paste the full Atlas connection string:
MONGODB_URI=mongodb+srv://USER:PASSWORD@plants.hjmpuck.mongodb.net/?appName=Plants

# Option B — if Atlas gave you user/password separately (seed.py will build the URI;
# special characters in the password are encoded automatically):
# MONGODB_USER=gardenuser
# MONGODB_PASSWORD=your-password-here

MONGODB_DB=plantapp

# PlantNet — https://my.plantnet.org (for the backend /identify route)
PLANTNET_API_KEY=
PLANTNET_PROJECT=all
