# Copy to .env at repo root and fill in — never commit real values.

MONGODB_URI=
MONGODB_DB=plantapp
MONGODB_USER=
MONGODB_PASSWORD=

# PlantNet — https://my.plantnet.org
PLANTNET_API_KEY=
PLANTNET_PROJECT=all

# Perenual — https://perenual.com/docs/api (care-field verification)
PERENUAL_API_KEY=

# YouTube Data API v3 — Search tab videos
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
# (GOOGLE_API_KEY works too if YouTube Data API is enabled on that key)
YOUTUBE_API_KEY=

# Optional: Google Custom Search for web guides in Search
# 1. Enable Custom Search API
# 2. Create an engine at https://programmablesearchengine.google.com/
# 3. Set GOOGLE_CSE_ID to the engine's cx value
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Auth0 — friends/leaderboard login. Create a Single Page Application +
# an API in your Auth0 dashboard (https://manage.auth0.com), then set:
#   AUTH0_DOMAIN   = the tenant domain, e.g. your-tenant.us.auth0.com
#   AUTH0_AUDIENCE = the API's Identifier (not the SPA client id)
# Leave blank to keep the app fully local — the leaderboard tab just
# shows a "not configured" state and nothing else is affected.
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
