# Copy to app/.env.local and fill in — never commit real values.

# Backend URL. Defaults to http://localhost:8000 if unset.
VITE_API_URL=http://localhost:8000

# Auth0 — friends/leaderboard login (Profile tab). Create a Single Page
# Application in your Auth0 dashboard (https://manage.auth0.com):
#   - Application type: Single Page Application
#   - Allowed Callback / Logout / Web Origins: http://localhost:5173
#   - VITE_AUTH0_DOMAIN     = the tenant domain, e.g. your-tenant.us.auth0.com
#   - VITE_AUTH0_CLIENT_ID  = the SPA's Client ID
#   - VITE_AUTH0_AUDIENCE   = the Identifier of the API you created for the
#                             backend (must match backend AUTH0_AUDIENCE)
# Leave these blank to keep the app fully local — the leaderboard section
# just shows a "not configured" message and nothing else is affected.
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
